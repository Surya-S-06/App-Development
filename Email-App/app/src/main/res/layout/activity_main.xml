<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✉️ Compose Email"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#1565C0"
            android:gravity="center"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Fill in the details below to send an email"
            android:textSize="13sp"
            android:textColor="#607D8B"
            android:gravity="center"
            android:layout_marginBottom="28dp"/>

        <!-- To Field -->
        <TextView
            android:id="@+id/textView5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="To (Recipient Email)"
            android:textSize="14sp"
            android:textColor="#37474F"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/editTextText4"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:ems="10"
            android:inputType="textEmailAddress"
            android:hint="recipient@example.com"
            android:paddingStart="12dp"
            android:background="@drawable/edit_text_bg"
            android:layout_marginBottom="16dp"/>

        <!-- CC Field (Enhancement) -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CC (Optional)"
            android:textSize="14sp"
            android:textColor="#37474F"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/editTextCC"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:ems="10"
            android:inputType="textEmailAddress"
            android:hint="cc@example.com (optional)"
            android:paddingStart="12dp"
            android:background="@drawable/edit_text_bg"
            android:layout_marginBottom="16dp"/>

        <!-- Subject Field -->
        <TextView
            android:id="@+id/textView6"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Subject"
            android:textSize="14sp"
            android:textColor="#37474F"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/editTextText6"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:ems="10"
            android:inputType="text"
            android:hint="Email subject"
            android:paddingStart="12dp"
            android:background="@drawable/edit_text_bg"
            android:layout_marginBottom="16dp"/>

        <!-- Message Field -->
        <TextView
            android:id="@+id/textView7"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Message"
            android:textSize="14sp"
            android:textColor="#37474F"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/editTextText7"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:ems="10"
            android:inputType="textMultiLine"
            android:hint="Type your message here…"
            android:paddingStart="12dp"
            android:paddingTop="12dp"
            android:gravity="top"
            android:background="@drawable/edit_text_bg"
            android:layout_marginBottom="24dp"/>

        <!-- Validation Error Label (Enhancement) -->
        <TextView
            android:id="@+id/tvError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#D32F2F"
            android:textSize="13sp"
            android:layout_marginBottom="8dp"/>

        <!-- Buttons Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">

            <Button
                android:id="@+id/btnClear"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="Clear"
                android:textColor="#37474F"
                android:backgroundTint="#E0E0E0"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/button2"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="✉ Send Email"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1565C0"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>